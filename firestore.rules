rules_version = '2';
service cloudfirestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Candidate Schema Validation Helper
    function isValidCandidate(candidate) {
      return candidate.keys().hasAll(['id', 'name', 'position', 'status', 'hrResult', 'userResult', 'notes', 'dateAdded', 'source'])
        && candidate.keys().size() == 9
        && (candidate.id is int || candidate.id is float)
        && candidate.name is string && candidate.name.size() > 0 && candidate.name.size() <= 100
        && candidate.position is string && candidate.position.size() > 0 && candidate.position.size() <= 100
        && candidate.status is string && candidate.status.size() > 0 && candidate.status.size() <= 50
        && candidate.hrResult is string && candidate.hrResult.size() > 0 && candidate.hrResult.size() <= 50
        && candidate.userResult is string && candidate.userResult.size() > 0 && candidate.userResult.size() <= 50
        && candidate.notes is string && candidate.notes.size() <= 1000
        && candidate.dateAdded is string && candidate.dateAdded.size() > 0 && candidate.dateAdded.size() <= 20
        && candidate.source is string && candidate.source.size() > 0 && candidate.source.size() <= 100;
    }

    // Rules for candidates collection
    match /candidates/{candidateDocId} {
      allow read: if isEmailVerified();
      
      allow create: if isEmailVerified() 
        && isValidId(candidateDocId) 
        && isValidCandidate(incoming());
        
      allow update: if isEmailVerified() 
        && isValidId(candidateDocId) 
        && isValidCandidate(incoming())
        && incoming().id == existing().id; // immutable internal ID field
        
      allow delete: if isEmailVerified();
    }

    // Rules for config collection
    match /config/{configDocId} {
      allow read: if isEmailVerified();
      allow write: if isEmailVerified();
    }
  }
}
